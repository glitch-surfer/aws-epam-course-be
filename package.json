    "clear-db": "ts-node --esm scripts/clear-db-standalone.js"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.14",
    "@types/node": "22.7.9",
    "aws-cdk": "2.1029.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@aws-cdk/aws-s3-deployment": "^1.203.0",
    "@aws-sdk/client-dynamodb": "^3.893.0",
    "@aws-sdk/client-s3": "^3.901.0",
    "@aws-sdk/client-sqs": "^3.908.0",
    "@aws-sdk/lib-dynamodb": "^3.893.0",
    "@aws-sdk/s3-request-presigner": "^3.901.0",
    "@types/uuid": "^10.0.0",
    "aws-cdk-lib": "2.214.0",
    "aws-sdk": "^2.1692.0",
    "constructs": "^10.0.0",
    "csv-parser": "^3.2.0",
    "uuid": "^13.0.0",
    "dotenv": "^16.4.5"
