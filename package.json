{
  "name": "aws-epam-course-be",
  "version": "0.1.0",
  "bin": {
    "aws-epam-course-be": "bin/aws-epam-course-be.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "cdk": "cdk",
    "deploy": "npm run build && cdk deploy --all",
